{
  "manifest_version": 3,
  "name": "公開ページ・YouTube・表示品質レビュー",
  "version": "0.1.0",
  "description": "公開ページ・YouTube・表示品質レビュー closed alpha extension",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
